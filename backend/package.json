  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "node dist/tests/run-tests.js",
    "test:build": "npm run build && node dist/tests/run-tests.js",
