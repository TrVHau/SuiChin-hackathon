NODE_ENV=production

# Railway injects PORT automatically. Do not hardcode PORT unless you know why.
CORS_ORIGINS=https://your-frontend.vercel.app

# Use prisma on Railway so PvP escrow/indexer state survives restarts.
BACKEND_STORAGE=prisma
MATCHMAKING_BACKEND=memory
CHAIN_ADAPTER=mock

# Add a Railway PostgreSQL plugin and reference its DATABASE_URL here.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Optional. Enable only if you add a Railway Redis plugin and update code/config to use it.
REDIS_URL=

SUI_NETWORK=devnet
SUI_RPC_URL=https://fullnode.devnet.sui.io:443
SUI_PACKAGE_ID=0xe892747fe1ffd30d15a1013cb7c5f801d0b3402831afa2b48090f64afa318e6b

LOBBY_PACKAGE_ID=0xe892747fe1ffd30d15a1013cb7c5f801d0b3402831afa2b48090f64afa318e6b
LOBBY_CONFIG_OBJECT_ID=0xa0fabdd9eaf6305ff9b4e58f1df6f0ce0d795b3502aa7665c7ebfb3aea917ea9

# Keep these secret. Never put real private keys in git.
ADMIN_SECRET_KEY=
LOBBY_SIGNER_SECRET_KEY=

# Optional timers. Emergency delay should stay short because room deadline is 3 minutes.
LOBBY_SETTLEMENT_TTL_MS=120000
LOBBY_EMERGENCY_REFUND_DELAY_MS=300000
PVP_QUEUE_TIMEOUT_MS=120000
PVP_LOCK_TIMEOUT_MS=45000
PVP_DISCONNECT_GRACE_MS=15000
