generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchMode {
  REALTIME
  ASYNC
}

enum ChallengeStatus {
  OPEN
  ACCEPTED
  ACTIVE
  SUBMITTED
  FINALIZED
  CANCELLED
  EXPIRED
}

enum MatchResult {
  WIN
  LOSE
  DRAW
  FORFEIT
}

model Challenge {
  id              String          @id
  mode            MatchMode
  status          ChallengeStatus
  challengerWallet String
  opponentWallet  String?
  stakeEnabled    Boolean         @default(false)
  stakeAmount     Int             @default(0)
  winnerWallet    String?
  createdAt       DateTime        @default(now())
  expiresAt       DateTime

  results         ChallengeResult[]

  @@index([status])
  @@index([challengerWallet])
  @@index([opponentWallet])
}

model ChallengeResult {
  id            String      @id
  challengeId   String
  walletAddress String
  result        MatchResult
  submittedAt   DateTime    @default(now())

  challenge     Challenge   @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, walletAddress])
  @@index([challengeId])
}

// ----------------------------------------------------------------------------
// INDEXER DOMAIN ENTITIES (Unit 1)
// ----------------------------------------------------------------------------

model SyncState {
  id             Int      @id @default(1) // Singleton pattern
  cursorTxDigest String
  cursorEventSeq String
  updatedAt      DateTime @updatedAt
}

model CraftEvent {
  id            String   @id @default(uuid())
  txDigest      String
  eventSeq      String
  playerAddress String
  itemMintedId  String
  itemType      String
  timestampMs   BigInt

  createdAt     DateTime @default(now())

  @@unique([txDigest, eventSeq])
  @@index([playerAddress])
  @@index([itemType])
}

model MatchEvent {
  id            String   @id @default(uuid())
  txDigest      String
  eventSeq      String
  roomId        String
  winnerAddress String
  loserAddress  String
  pointChange   Int
  timestampMs   BigInt

  createdAt     DateTime @default(now())

  @@unique([txDigest, eventSeq])
  @@index([winnerAddress])
  @@index([loserAddress])
}

model FusionEvent {
  id            String   @id @default(uuid())
  txDigest      String
  eventSeq      String
  playerAddress String
  inputItemIds  String[]
  outputItemId  String
  timestampMs   BigInt

  createdAt     DateTime @default(now())

  @@unique([txDigest, eventSeq])
  @@index([playerAddress])
}

model MarketplaceListing {
  id            String   @id @default(uuid())
  txDigest      String
  eventSeq      String
  sellerAddress String
  itemId        String
  price         BigInt
  status        String   @default("ACTIVE") // ACTIVE, CANCELLED, SOLD
  timestampMs   BigInt

  createdAt     DateTime @default(now())

  @@unique([txDigest, eventSeq])
  @@index([sellerAddress])
  @@index([status])
}
